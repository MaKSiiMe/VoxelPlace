PORT=3001

# Redis — grille de pixels et temps réel
REDIS_URL=redis://100.124.153.20:6379

# PostgreSQL — comptes utilisateurs
DATABASE_URL=postgresql://voxelplace:changeme@localhost:5432/voxelplace

# Sécurité
ADMIN_PASSWORD=changeme
JWT_SECRET=change_this_secret_in_production

# CORS — origines autorisées (séparées par des virgules)
# En production : NEXT_PUBLIC_API_URL et ALLOWED_ORIGINS doivent pointer vers le même domaine public
# Ex: ALLOWED_ORIGINS=https://s56c-srv.tailedae07.ts.net
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# URL publique de l'API (build-time Next.js — doit être défini AVANT docker compose up --build)
# En production avec nginx reverse proxy sur port 80 : NEXT_PUBLIC_API_URL=https://mondomaine.tld
# En local sans nginx : NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost

# Comptes sans cooldown (séparés par des virgules) — laisser vide en prod
TEST_USERNAMES=
